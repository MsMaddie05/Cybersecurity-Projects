# template.yaml
apiVersion: v1
kind: Config
current-context: {{.ClusterName}}
clusters:
- name: {{.ClusterName}}
  cluster:
    server: {{.APIServerURL}}
contexts:
- name: {{.ClusterName}}
  context:
    cluster: {{.ClusterName}}
    user: {{.UserName}}
users:
- name: {{.UserName}}
  user:
    token: {{.Token}}
